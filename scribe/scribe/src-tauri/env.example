# Scribe env: copy this file to .env in this directory (src-tauri/.env) and set values.
# The app loads .env at startup. Never commit .env or real API keys.

# --- Planner (Ollama) ---
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2

# --- Intent router: prototype file (intents + example phrases) ---
# Path to intent_prototypes.json. If unset, tries ./intent_prototypes.json then ./src-tauri/intent_prototypes.json.
# INTENT_PROTOTYPES_PATH=path/to/intent_prototypes.json

# --- Intent router: cache and threshold ---
# ROUTER_CACHE_SIZE=500   (max cached routing results by goal hash; default 500)
# ROUTER_FAST_PATH_THRESHOLD=0.82   (min similarity for direct path; default 0.82)

# --- Intent router: backend embedding API ---
# Base URL of your backend embedding service (cross-platform). App calls POST {url}/embed with
# {"texts": ["..."]} and expects {"embeddings": [[...floats...]]}.
# EMBEDDING_SERVICE_URL=https://your-backend.example.com
