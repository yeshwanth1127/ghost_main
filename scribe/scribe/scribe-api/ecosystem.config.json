{
  "apps": [
    {
      "name": "ghost-api",
      "script": "/var/www/ghost/ghost_main/scribe/scribe/scribe-api/target/release/ghost-api",
      "cwd": "/var/www/ghost/ghost_main/scribe/scribe/scribe-api",
      "instances": 1,
      "exec_mode": "fork",
      "error_file": "/var/www/ghost/ghost_main/scribe/scribe/scribe-api/logs/ghost-api-error.log",
      "out_file": "/var/www/ghost/ghost_main/scribe/scribe/scribe-api/logs/ghost-api-out.log",
      "log_file": "/var/www/ghost/ghost_main/scribe/scribe/scribe-api/logs/ghost-api.log",
      "time": true,
      "autorestart": true,
      "watch": false,
      "max_memory_restart": "500M",
      "merge_logs": true,
      "kill_timeout": 5000,
      "listen_timeout": 10000
    }
  ]
}
