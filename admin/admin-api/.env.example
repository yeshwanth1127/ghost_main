# Same database as scribe-api (required)
DATABASE_URL=postgresql://user:pass@localhost:5432/ghost

# Optional: copy from scribe-api/.env or set here
# Admin credentials are in admin_users table (default: admin / ghostadmin123)

# JWT secret (optional, has default)
# ADMIN_SECRET=ghost-admin-jwt-secret-2025

# Port (default 6660)
# ADMIN_PORT=6660

# Razorpay (for subscriptions)
# RAZORPAY_KEY_ID=rzp_test_xxx
# RAZORPAY_KEY_SECRET=xxx
# RAZORPAY_WEBHOOK_SECRET=xxx
# RAZORPAY_PLAN_STARTER=plan_xxx
# RAZORPAY_PLAN_PRO=plan_xxx
# RAZORPAY_PLAN_POWER=plan_xxx

# Email for OTP (Resend API - free 100/day, verify domain at resend.com)
RESEND_API_KEY=re_xxxxxxxxxxxx
SMTP_FROM_EMAIL=support@exora.solutions
