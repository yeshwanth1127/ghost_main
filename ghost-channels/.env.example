# Paste your Telegram bot token from @BotFather to enable Telegram.
# GHOST_TELEGRAM_BOT_TOKEN=123456789:ABCdef...

# Optional: gateway URL (default: ws://127.0.0.1:8083/gateway)
# GHOST_GATEWAY_URL=ws://127.0.0.1:8083/gateway

# Optional: path to WhatsApp auth directory to enable WhatsApp (first run shows QR)
# GHOST_WHATSAPP_AUTH_DIR=C:\Users\admin\.ghost\wa-auth
