# Required for scribe-api (Docker)
# Copy to project root as .env before: docker compose up

# API key - must match Scribe desktop app
API_ACCESS_KEY=your-secret-access-key-here

# OpenRouter (for chat/LLM)
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# OpenAI (for Whisper STT)
OPENAI_API_KEY=your-openai-api-key

# Optional: override DATABASE_URL to use production DB for shared licenses
# Leave unset to use local Postgres (postgresql://ghost:ghost@postgres:5432/ghost)
# DATABASE_URL=postgresql://user:pass@your-db-host:5432/ghost

# Optional: logging
# RUST_LOG=ghost_api=debug,info
